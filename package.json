{
  "name": "witness-cipher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "start": "node build/bin/server.js",
    "build": "node ace build",
    "heroku-postbuild": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "node --test test/opensslEnvelope.test.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "imports": {
    "#exceptions/*": "./app/exceptions/*.js",
    "#services/*": "./app/services/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "~24.11.0",
    "eslint": "^10.0.2",
    "hot-hook": "^1.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "youch": "^4.1.0"
  },
  "dependencies": {
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/session": "^8.0.0",
    "@adonisjs/shield": "^9.0.0",
    "@adonisjs/static": "^2.0.0",
    "@adonisjs/vite": "^5.1.0",
    "edge.js": "^6.5.0",
    "luxon": "^3.7.2",
    "reflect-metadata": "^0.2.2"
  },
  "hotHook": {
    "boundaries": [
      "./app/middleware/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
